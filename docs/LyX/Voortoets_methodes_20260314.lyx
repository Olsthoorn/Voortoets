\begin_layout Standard
Dit is nog niet het hele verhaal.
 De oplossing voor de radiale stroming heeft een eindige waarde op 
\begin_inset Formula $x\to\infty$
\end_inset

 in plaats van 
\begin_inset Formula $0$
\end_inset

.
 Deze moet nog van de radiale stroming worden afgetrokken.
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\Omega\left(\xi\to\infty\right) & =\frac{2Q}{\pi}\ln\left(\sin\left(i\frac{\pi\xi}{2D}\right)\right)-\frac{Q}{D}\xi\\
 & =\frac{2Q}{\pi}\ln\left(i\sinh\left(\frac{\pi\xi}{2D}\right)\right)-\frac{Q}{D}\xi\\
 & =\frac{2Q}{\pi}\ln\left(i\exp\left(\frac{\pi\xi}{2D}\right)\frac{1}{2}\right)-\frac{Q}{D}\xi\\
 & =\frac{2Q}{\pi}\ln i+\frac{2Q}{\pi}\frac{\pi\xi}{2D}-\frac{2Q}{\pi}\ln\left(2\right)\\
 & =iQ-\frac{2Q}{\pi}\ln2
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
We moeten de waarde 
\begin_inset Formula $\frac{2Q}{\pi}\ln2$
