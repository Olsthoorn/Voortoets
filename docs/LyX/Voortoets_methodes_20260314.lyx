\begin_layout Standard
De analytische formule de verlaging van het grondwater beschrijft na een plotselinge verandering van het peil in een gracht of sleuf,
 is als volgt
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
h\left(x,t\right)=h_{0}\mathtt{erfc}\left(u\right),\,\,\,\mathtt{waar}\,\,\,u=\sqrt{\frac{x^{2}S}{4kDt}}
\]

\end_inset

waarin 
\begin_inset Formula $\mathtt{erfc}\left(\right)$
\end_inset

 de 
\bar under
complementaire error-functie
\bar default
 is.
 Met deze formule kan voor elk tijdstip worden berekend waar de 5 cm verlagingslijn zich bevindt
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
x=\sqrt{\frac{4kDt}{S}}\mathtt{\mathtt{erfc^{-1}}}\left(\frac{h_{5cm}}{h_{0}}\right)
\]

\end_inset


\end_layout

\begin_layout Standard
Hierin is 
\begin_inset Formula $\mathtt{erfc^{-1}}()$
\end_inset

 de inverse is van de 
\begin_inset Formula $\mathtt{erfc()}$
\end_inset

 functie,
 die gemakkelijk te berekenen is.
