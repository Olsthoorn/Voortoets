\begin_layout Subsection
Verticale anisotropie in de radiale weerstand
\end_layout

\begin_layout Standard
De partiële differentiaal vergelijking die de grondwater in het verticale vlak beschrijft is als volgt
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
k_{x}\frac{\partial^{2}\phi}{\partial x^{2}}+k_{z}\frac{\partial^{2}\phi}{\partial z^{2}}=S_{s}\frac{\partial\phi}{\partial t}-q=R
\]

\end_inset


\end_layout

\begin_layout Standard
Hierin staan berging en andere opgelegde stromen aan de rechterzijde van het isgelijkteken.
 Het rechterlid wordt verder gemakshalve samengevat in de term 
\begin_inset Formula $R$
\end_inset

.
\end_layout

\begin_layout Standard
Vermenigvuldig de termen links met 
\begin_inset Formula $\frac{k}{k}$
\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\frac{k_{x}}{k}k\frac{\partial^{2}\phi}{\partial x^{2}}+\frac{k_{z}}{k}k\frac{\partial^{2}\phi}{\partial z^{2}}=R
\]

\end_inset

waarna we de 
\begin_inset Formula $x$
\end_inset

- en de 
\begin_inset Formula $z$
\end_inset

-coördinaat kunnen verschalen en de volgende differentiaalvergelijking wordt verkregen
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
k\frac{\partial^{2}\phi}{\partial\left(\sqrt{\frac{k}{k_{x}}}x\right)^{2}}+k\frac{\partial^{2}\phi}{\partial\left(\sqrt{\frac{k}{k_{z}}}z\right)^{2}}=R
\]

\end_inset

Deze is te schrijven met coördinaten 
\begin_inset Formula $\overline{x}$
\end_inset

 en 
\begin_inset Formula $\overline{z}$
\end_inset

,
 waardoor de vergelijking van een anisotroop pakket overgaat in die van een een isotroop watervoerende pakket met 
\begin_inset Formula $k$
\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
k\frac{\partial^{2}\phi}{\partial\overline{x}^{2}}+k\frac{\partial^{2}\phi}{\partial\overline{z}^{2}}=R
\]

\end_inset

Voor de nieuwe coördinaten geldt 
\begin_inset Formula $\overline{x}=x\sqrt{\frac{k}{k_{x}}}$
\end_inset

 en 
\begin_inset Formula $\overline{\ensuremath{z}}=\sqrt{\frac{k}{k_{z}}}$
\end_inset

.
 De keuze van doorlatendheid 
\begin_inset Formula $k$
\end_inset

 is geheel vrij.
 De verschaling maakt niets uit voor het rechterlid.
 Dus blijven de voeding,
 de berging en de onttrekking gelijk aan de isotrope situatie.
 Dit geldt voor alle debieten.
\end_layout

\begin_layout Standard
Het is gebruikelijk 
\begin_inset Formula $k=\sqrt{k_{x}k_{z}}$
\end_inset

 te kiezen.
 Dit is de verschaling die het dichtst bij de oorspronkelijke doorsnede blijft.
 Dit betekent dat wanneer we in ons oorspronkelijke pakket 
\begin_inset Formula $x$
\end_inset

 naar 
\begin_inset Formula $\overline{x}$
\end_inset

 en 
\begin_inset Formula $z$
\end_inset

 naar 
\begin_inset Formula $\overline{z}$
\end_inset

 verschalen,
 we in het verschaalde isotrope pakket niet alleen dezelfde stroming maar ook dezelfde stijghoogten krijgen.
 In dit verschaalde isotrope pakket staan de stijghoogte- en stroomlijnen loodrecht op elkaar.
\end_layout

\begin_layout Section
Radiale weerstand met verticale anisotropie
\end_layout

\begin_layout Standard
Wanneer we 
\begin_inset Formula $r$
\end_inset

 opvatten als slootbreedte en dus als coördinaat in 
\begin_inset Formula $x$
\end_inset

-richting dan is verschaling van
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\Delta\phi=\frac{2Q}{\pi k}\ln\left(2i\sinh\left(\frac{\pi r}{2D}\right)\right)-\frac{Q}{kD}r
\]

\end_inset


\end_layout

\begin_layout Standard
als volgt met
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\frac{r}{D}\to\frac{r\sqrt{\frac{k}{k_{x}}}}{D\sqrt{\frac{k}{k_{z}}}}=\frac{r}{D}\sqrt{\frac{k_{z}}{k_{x}}}
\]

\end_inset


\end_layout

\begin_layout Standard
en
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\frac{Q}{kD}=\frac{Q}{k_{x}D}r\to\frac{Q}{k_{x}}\frac{r}{D}\sqrt{\frac{k_{z}}{k_{x}}}=\frac{Q}{k}\frac{r}{D}\sqrt{\frac{k_{z}}{k_{x}}}
\]

\end_inset


\end_layout

\begin_layout Standard
De extra stijghoogte in de situatie met anisotropie wordt hiermee beschreven door
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\Delta\phi=\frac{2Q}{\pi\sqrt{k_{x}k_{z}}}\ln\left(2i\sinh\left(\frac{\pi r}{2D}\sqrt{\frac{k_{z}}{k_{x}}}\right)\right)-\frac{Q}{\sqrt{k_{x}k_{z}}}\frac{r}{D}\sqrt{\frac{k_{z}}{k_{x}}}
\]

\end_inset


\backslash

\end_layout

\begin_layout Standard
Voor de eenvoudige formule met anisotropie geldt
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\Delta\phi=\frac{2Q}{\pi k}\ln\left(\frac{\pi r}{D}\right)\to\Delta\phi=\frac{2Q}{\pi\sqrt{k_{x}k_{z}}}\ln\left(\frac{r}{D}\sqrt{\frac{k_{z}}{k_{x}}}\right)
\]

\end_inset


\end_layout

\begin_layout Section
De lekweerstand en parametergevoeligheid met verticale anisotropie
\end_layout

\begin_layout Standard
De lekweerstand 
\begin_inset Formula $c_{L}$
\end_inset

 [d] is de gemiddelde grondwaterstand 
\begin_inset Formula $\overline{\phi}$
\end_inset

 [m] minus het slootpeil 
\begin_inset Formula $\phi_{sl}$
\end_inset

 [m] gedeeld door het neerslagoverschot 
\begin_inset Formula $N$
\end_inset

 [m/d] 
\begin_inset Formula $Q$
\end_inset

.
 Het is de som van het stijghoogteverval door horizontale stroming,
 door de contractie van stroming nabij de sloot en door passage van een sliblaag op de slootbodem.
 De sliblaag heeft een weerstand 
\begin_inset Formula $c_{slb}$
\end_inset

 [d].
 Het stijghoogteverval kan dus vanwege 
\begin_inset Formula $Q=NL/2$
\end_inset

 geschreven worden als de som van drie termen 
\begin_inset Formula $\Delta\phi_{h}+\Delta\phi_{r}+\Delta\phi_{sl}$
\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\Delta\phi & =\overline{\phi}-\phi_{sl}\\
 & =\Delta\phi_{h}+\Delta\phi_{r}+\Delta\phi_{sl}\\
 & =\frac{NL^{2}}{12k_{x}D}-\left(\frac{NL}{\pi\sqrt{k_{x}k_{z}}}\ln\left(2\sinh\left(\frac{\pi r}{2D}\sqrt{\frac{k_{x}}{k_{z}}}\right)\right)-\frac{NL/2}{\sqrt{k_{x}k_{z}}}\frac{r}{D}\right)+\frac{NL}{\pi r}c_{slb}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
De gebiedsgemiddelde lekweerstand 
\begin_inset Formula $c_{L}$
\end_inset

 [d] krijgen we door deling van het totale stijghoogteverval 
\begin_inset Formula $\Delta\phi$
\end_inset

 door het neerslagoverschot 
\begin_inset Formula $N$
\end_inset

 [m/d]
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
c_{L} & =\frac{\overline{\phi}-\phi_{sl}}{N}\\
 & =c_{h}+c_{r}+c_{sl}\\
 & =\frac{L^{2}}{12k_{x}D}-\left(\frac{L}{\pi\sqrt{k_{x}k_{z}}}\ln\left(2\sinh\left(\frac{\pi r}{2D}\sqrt{\frac{k_{x}}{k_{z}}}\right)\right)-\frac{L/2}{\sqrt{k_{x}k_{z}}}\frac{r}{D}\right)+\frac{L}{\pi r}c_{slb}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Deze drie termen hebben alle dimensie tijd,
 dus meestal [d].
 De laatste twee termen kunnen ook begrepen worden als het stijghoogteverlies tet plaatse van de sloot.
 Maar dan moet niet door 
\begin_inset Formula $N$
\end_inset

 maar door 
\begin_inset Formula $NL$
\end_inset

 worden gedeeld en wordt de dimensie [d/m] in plaats van dag.
 
\begin_inset Formula $NL$
\end_inset

 is dan het debiet per m slootlengte dat de sloot draineert.
\end_layout

\begin_layout Standard
Dezelfde uitwerking voor de vereenvoudigde formule voor radiale weerstand levert
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
c_{L} & =\frac{\overline{\phi}-\phi_{sl}}{N}\\
 & =\frac{L^{2}}{12k_{x}D}-\frac{1}{\pi\sqrt{k_{x}k_{z}}}\ln\left(\frac{\pi r}{D}\sqrt{\frac{k_{x}}{k_{z}}}\right)+\frac{L}{\pi r}c_{slb}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
.
\end_layout

\begin_layout Standard
Figuur 
\begin_inset CommandInset ref
LatexCommand ref
reference "fig:Gevoeligheidsanalyse-van-de-drainageweerstand"
plural "false"
