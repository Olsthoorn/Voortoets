\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align}
\Omega & =\frac{2Q}{\pi}\ln\left(\sin\left(i\frac{\pi\xi}{2D}\right)\right)-\frac{Q}{D}\xi+\frac{2Q}{\pi}\ln2\nonumber \\
 & =\frac{2Q}{\pi}\ln\left(2\sin\left(i\frac{\pi\xi}{2D}\right)\right)-\frac{Q}{D}\xi\label{eq:Omega-radial1}
\end{align}

\end_inset


\end_layout

