\delta & =0.61\times\beta\sqrt{\hat{y}}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Kiezen we 
\begin_inset Formula $\delta$
\end_inset

,
 de 
\begin_inset Quotes pld
\end_inset

halve slootbreedte
\begin_inset Quotes prd
\end_inset

 voor 
\begin_inset Formula $y=0$
\end_inset

 dan volgt
